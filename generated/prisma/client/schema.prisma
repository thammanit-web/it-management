generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee   Employee? @relation(fields: [employeeId], references: [id])
  employeeId String?   @unique

  requests          Request[]
  comments          Comment[]
  equipmentRequests EquipmentRequest[]
  equipmentGroups   EquipmentBorrowGroup[]
  auditLogs         AuditLog[]
  itNotes           ItNote[]
  incidentReports   IncidentReport[]
}

model Employee {
  id               String           @id @default(cuid())
  employee_code    String           @unique
  employee_name_th String
  employee_name_en String?
  gender           String?
  position         String?
  department       String?
  work_location    String?
  supervisor_name  String?
  start_date       DateTime?
  end_date         DateTime?
  status           String?
  requests         Request[]
  user             User?
  assets           Asset[]
  credentials      UserCredential[]

  @@map("employees")
}

enum Category {
  HARDWARE
  SOFTWARE
  NETWORK
  GENERAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Request {
  id                  String    @id @default(cuid())
  employeeId          String
  employee            Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  request_code        String    @unique
  type_request        String
  description         String
  reason              String?
  category            Category
  priority            Priority
  status              Status    @default(OPEN)
  approval            String?
  approval_status     String?
  approval_comment    String?
  approval_date       DateTime?
  it_approval         String?
  it_approval_status  String?
  it_approval_comment String?
  it_approval_date    DateTime?
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments            Comment[]
  attachment          String? // Added for user to attack images
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([employeeId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  parentId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([userId])
  @@index([createdAt])
}

model EquipmentPurchaseOrder {
  id           String   @id @default(cuid())
  po_code      String?  @unique
  list         String?
  detail       String?
  quantity     Int      @default(0)
  reason_order String?
  picture      String?
  buyer        String?
  reviewer     String?
  approver     String?
  date_order   DateTime @default(now())
  status       String   @default("PENDING")

  entries EquipmentEntryList[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("equipment_purchase_orders")
}

model EquipmentEntryList {
  id            String                 @id @default(cuid())
  purchase_id   String
  purchaseOrder EquipmentPurchaseOrder @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  list          String?
  brand_name    String?
  quantity      Int                    @default(0)
  unit          String?
  recipient     String?
  date_received DateTime?
  item_type     String                 @default("MAIN")

  equipmentLists EquipmentList[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("equipment_entry_lists")
}

model EquipmentList {
  id                 String             @id @default(cuid())
  eq_code            String?            @unique
  equipment_entry_id String
  equipmentEntry     EquipmentEntryList @relation(fields: [equipment_entry_id], references: [id], onDelete: Cascade)
  payout_amount      Float?
  remaining          Int                @default(0)
  status             String?

  requests EquipmentRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("equipment_lists")
}

model EquipmentRequest {
  id                String         @id @default(cuid())
  equipment_code    String         @unique
  equipment_list_id String?
  equipmentList     EquipmentList? @relation(fields: [equipment_list_id], references: [id], onDelete: Cascade)
  manual_item_name  String?
  manual_item_type  String?
  quantity          Int            @default(1)
  reason            String?
  remarks           String?

  // New: Link to Batch/Group
  groupId String?
  group   EquipmentBorrowGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // New: Borrow Reason Type (based on new form)
  borrow_type String? @default("NEW") // NEW, BROKEN, OTHER

  approval            String?
  approval_status     String?
  approval_comment    String?
  approval_date       DateTime?
  it_approval         String?
  it_approval_status  String?
  it_approval_comment String?
  it_approval_date    DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("equipment_requests")
}

model EquipmentBorrowGroup {
  id         String  @id @default(cuid())
  group_code String  @unique
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason     String?

  approval         String?
  approval_status  String?   @default("PENDING")
  approval_comment String?
  approval_date    DateTime?

  it_approval         String?
  it_approval_status  String?   @default("PENDING")
  it_approval_comment String?
  it_approval_date    DateTime?

  date_needed DateTime?

  requests EquipmentRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("equipment_borrow_groups")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  userName  String?
  action    String
  module    String
  details   String?
  ipAddress String?
  userAgent String?
  device    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

model Asset {
  id            String @id @default(cuid())
  // รหัสทรัพย์สิน เช่น NDCPC0001, NDCNB0001, NDCSC0001
  asset_code    String @unique
  serial_number String @unique

  // ประเภทอุปกรณ์: PC, NOTEBOOK, SCREEN, PRINTER
  type  String
  name  String // ชื่อเรียกเครื่อง เช่น Notebook Admin 01
  brand String?
  model String?
  specs String? @db.Text

  // ข้อมูลการจัดซื้อและประกัน
  purchase_date   DateTime?
  warranty_expire DateTime?
  price           Float?    @default(0)

  // สถานะปัจจุบัน: AVAILABLE, IN_USE, REPAIR, SCRAP
  status String @default("AVAILABLE")

  // สถานที่ตั้งปัจจุบัน (เช่น Office Rayong, IT Room, Meeting Room A)
  location String?

  // ความสัมพันธ์: ใครเป็นคนใช้ (Current Holder)
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  // ประวัติการย้ายที่ตั้งหรือเปลี่ยนมือผู้ใช้
  history AssetHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("assets")
}

model AssetHistory {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  employeeId   String?
  employeeName String? // เก็บชื่อไว้เผื่อข้อมูลพนักงานถูกลบ
  location     String? // สถานที่ที่เคยตั้ง

  startDate DateTime  @default(now()) // เริ่มใช้/เริ่มตั้ง วันที่
  endDate   DateTime? // คืนเครื่อง/ย้ายที่ วันที่

  action  String? // เช่น "ASSIGN", "TRANSFER", "RETURN", "REPAIR"
  remarks String?

  createdAt DateTime @default(now())

  @@map("asset_history")
}

model UserCredential {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  account_type  String[] // EMAIL, FILE_SHARE, VPN, ERP, SOFTWARE, OTHER
  username      String
  password      String // แนะนำให้เข้ารหัส (Encrypted) ก่อนบันทึก
  email_address String? // สำหรับเก็บอีเมลโดยเฉพาะ
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_credentials")
}

model ItNote {
  id          String  @id @default(cuid())
  title       String
  isPrivate   Boolean @default(false)
  isPublished Boolean @default(false) // Show in Public Directory/Dashboard
  content     String? @db.Text
  attachment  String?

  details ItNoteDetail[]

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("it_notes")
}

model ItNoteDetail {
  id     String @id @default(cuid())
  noteId String
  note   ItNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  label String
  value String

  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("it_note_details")
}

model Notification {
  id      String  @id @default(cuid())
  title   String
  message String  @db.Text
  type    String  @default("INFO") // INFO, TICKET, EQUIPMENT, ALERT
  isRead  Boolean @default(false)
  link    String? // Optional link to navigate when clicked

  userId String? // If targeted at a specific user (e.g. an admin). If null, it's for all admins.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([isRead])
  @@map("notifications")
}

model IncidentReport {
  id          String  @id @default(cuid())
  report_code String? @unique

  // Reporter fields
  incidentTime        DateTime
  location            String
  employeeCode        String
  reporterName        String
  department          String
  incidentType        String // MALWARE, SYSTEM_DOWN, HUMAN_ERROR, UNAUTHORIZED_ACCESS, OTHER
  incidentTypeOther   String?
  details             String    @db.Text
  reportSignatureDate DateTime?
  reporterSign        String?

  // Maintenance fields
  cause           String?   @db.Text
  maintenanceDate DateTime?
  repairType      String? // EXTERNAL, INTERNAL
  resolution      String?   @db.Text
  prevention      String?   @db.Text

  responsibleSign    String?
  responsibleDate    DateTime?
  reviewerSign       String?
  reviewerDate       DateTime?
  maintenanceComment String?

  status String  @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("incident_reports")
}
